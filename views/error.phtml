<?php
    /** @var \Afterchange\Template\Utils\Translator $t */
    /** @var int $code */
    /** @var string $title */
    /** @var string $message */
    /** @var bool $debug */
    /** @var \Exception $exception */
?>
<div class="centered-container" style="text-align: center; max-width: 600px; padding: 4rem 1rem;">
    <h1 style="font-size: 5rem; letter-spacing: -0.05em; margin-bottom: 0; line-height: 1;"><?= $code ?></h1>
    <h2 style="font-size: 1.5rem; margin-bottom: var(--spacing-md); opacity: 0.8;">
        <?= ($t->hasTrans($title)) ? $t->trans($title) : '' ?>
    </h2>

    <p style="font-size: 1rem; opacity: 0.6; max-width: 450px; margin: 0 auto var(--spacing-lg) auto;">
        <?= $t->trans($message) ?>
    </p>

    <a href="/" class="secondary-button" style="min-width: unset;"><?= $t->trans('HOME') ?></a>
</div>

<?php if (isset($debug) && $debug && isset($exception)): ?>
    <div style="text-align: left; max-width: 1000px; margin: 2rem auto; background: var(--bg-surface); padding: 2rem; border-radius: var(--radius-md); font-family: monospace; border: 1px solid var(--border-color, #333);">
        <h3 style="color: var(--error, #e57373); margin-bottom: 1rem;"><?= get_class($exception) ?>: <?= htmlspecialchars($exception->getMessage()) ?></h3>
        <p style="opacity: 0.8; margin-bottom: 2rem;">In <?= $exception->getFile() ?> on line <?= $exception->getLine() ?></p>
        <pre style="white-space: pre-wrap; overflow-x: auto; font-size: 0.9em; opacity: 0.7;"><?= htmlspecialchars($exception->getTraceAsString()) ?></pre>
    </div>
<?php endif; ?>